# ============================================
# 开发环境配置
# 继承 .env 后覆盖以下值
# ============================================

# 环境标识
DENO_ENV=development

# Docker 镜像标签
IMAGE_TAG=dev

# 宿主机端口（开发环境使用 18080）
HOST_PORT=18080

# PostgREST
PGREST_URL=http://10.38.245.92:3007

# External auth service (token exchange)
IA_CSC_BASE_URL=http://10.38.211.67:39018/ia-csc

# 开发环境日志级别可以更详细
LOG_LEVEL=debug
