# ============================================
# 开发环境配置
# 继承 .env 后覆盖以下值
# ============================================

# 环境标识
DENO_ENV=development

# Docker 镜像标签
IMAGE_TAG=dev

# 宿主机端口（开发环境使用 18080）
HOST_PORT=18080

# PostgREST
PGREST_URL=http://10.38.245.92:3007

# PostgREST JWT (dev only — 临时或长效 token，不可用于生产环境)
# PGREST_JWT=your_pgrest_jwt_here

# 开发环境日志级别可以更详细
LOG_LEVEL=debug

# PostgreSQL 直连（用于 pg_* MCP 工具：建表/视图/存储过程/策略）
# 格式: postgresql://user:password@host:5432/database
#DATABASE_URL=
