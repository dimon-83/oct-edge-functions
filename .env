# ============================================
# 基础配置（所有环境共享）
# 敏感信息（密码、密钥等）请勿放入此文件
# ============================================

# CORS
CORS_ORIGIN=*

# Logging (debug | info | error)
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_BYTES=10485760
LOG_MAX_FILES=5

# Server
PORT=18080

# PostgREST Schema（通常所有环境一致）
PGREST_SCHEMA=public

# Docker 镜像配置
IMAGE_NAME=oct-edge-functions
