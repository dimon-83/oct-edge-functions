<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Database Triggers - Database Manager</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <!-- CSS_TOKEN_SLOT -->
</head>
<body>
  <style>
    /* === Project Shell Layout === */
    .project-shell {
      display: flex;
      flex-direction: column;
      height: 100vh;
      margin: 0;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 14px;
      color: #1a202c;
      background: #f7f8fa;
      overflow: hidden;
    }

    .project-shell *,
    .project-shell *::before,
    .project-shell *::after {
      box-sizing: border-box;
    }

    /* --- Header --- */
    .shell-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
      height: 48px;
      padding: 0 16px;
      background: #ffffff;
      border-bottom: 1px solid #e2e8f0;
      z-index: 100;
    }

    .shell-header__left {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .shell-header__org {
      font-size: 14px;
      font-weight: 500;
      color: #1a202c;
      white-space: nowrap;
    }

    .shell-header__badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.04em;
      line-height: 1;
      border-radius: 9999px;
      white-space: nowrap;
    }

    .shell-header__badge--free {
      background: #f1f3f5;
      color: #64748b;
    }

    .shell-header__badge--prod {
      background: #ecfdf5;
      color: #16a34a;
    }

    .shell-header__center {
      display: flex;
      align-items: center;
      gap: 8px;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .shell-header__breadcrumb {
      font-size: 14px;
      color: #1a202c;
      white-space: nowrap;
    }

    .shell-header__breadcrumb-sep {
      margin: 0 2px;
      color: #94a3b8;
    }

    .shell-header__right {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .shell-header__connect {
      display: inline-flex;
      align-items: center;
      padding: 4px 12px;
      font-size: 13px;
      font-weight: 500;
      color: #ffffff;
      background: #3ecf8e;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      white-space: nowrap;
    }

    .shell-header__connect:hover {
      background: #38b87f;
    }

    .shell-header__icon-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      color: #64748b;
      cursor: pointer;
      border: none;
      background: none;
      border-radius: 4px;
    }

    .shell-header__icon-btn:hover {
      background: #f1f3f5;
      color: #1a202c;
    }

    .shell-header__avatar {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: #e2e8f0;
      border: 1px solid #e2e8f0;
    }

    /* --- Body row: sidebar + main --- */
    .shell-body {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    /* --- Sidebar --- */
    .shell-sidebar {
      width: 240px;
      flex-shrink: 0;
      background: #ffffff;
      border-right: 1px solid #e2e8f0;
      overflow-y: auto;
      overflow-x: hidden;
    }

    .shell-sidebar::-webkit-scrollbar {
      width: 4px;
    }

    .shell-sidebar::-webkit-scrollbar-thumb {
      background: #e2e8f0;
      border-radius: 4px;
    }

    .shell-sidebar__section-title {
      padding: 20px 16px 6px 16px;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.08em;
      color: #64748b;
      text-transform: uppercase;
      line-height: 1;
    }

    .shell-sidebar__nav-item {
      display: block;
      padding: 8px 16px;
      font-size: 14px;
      color: #64748b;
      text-decoration: none;
      cursor: pointer;
      transition: background var(--transition-fast, 150ms ease), color var(--transition-fast, 150ms ease);
    }

    .shell-sidebar__nav-item:hover {
      color: #1a202c;
      background: #f7f8fa;
    }

    .shell-sidebar__nav-item[data-active="true"] {
      color: #1a202c;
      font-weight: 500;
      background: #f1f3f5;
    }

    /* --- Main content area --- */
    .shell-main {
      flex: 1;
      min-width: 0;
      overflow-y: auto;
      background: #f7f8fa;
    }

    /* ===== Page-specific: Database Triggers ===== */
    .trig-page {
      padding: 24px;
      max-width: 1280px;
    }

    /* Page header */
    .trig-page__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .trig-page__title {
      font-size: 24px;
      font-weight: 700;
      color: #1a202c;
      margin: 0;
      line-height: 1.25;
    }

    .trig-page__docs-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 13px;
      font-weight: 500;
      color: #64748b;
      text-decoration: none;
      white-space: nowrap;
      transition: color 150ms ease;
    }

    .trig-page__docs-link:hover {
      color: #1a202c;
    }

    /* Toolbar */
    .trig-toolbar {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }

    .trig-toolbar__schema-select {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      font-size: 13px;
      font-family: inherit;
      color: #1a202c;
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      cursor: pointer;
      line-height: 1;
      white-space: nowrap;
    }

    .trig-toolbar__search {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      font-size: 13px;
      font-family: inherit;
      color: #64748b;
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      min-width: 200px;
      outline: none;
      transition: border-color 150ms ease;
    }

    .trig-toolbar__search::placeholder {
      color: #94a3b8;
    }

    .trig-toolbar__search:focus {
      border-color: #3ecf8e;
    }

    .trig-toolbar__spacer {
      flex: 1;
    }

    .trig-toolbar__btn-new {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      font-size: 13px;
      font-weight: 500;
      font-family: inherit;
      color: #ffffff;
      background: #3ecf8e;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      white-space: nowrap;
      transition: background 150ms ease;
    }

    .trig-toolbar__btn-new:hover {
      background: #38b87f;
    }

    /* Data table */
    .trig-table-wrap {
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      overflow: hidden;
    }

    .trig-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }

    .trig-table thead th {
      text-align: left;
      padding: 10px 16px;
      font-size: 12px;
      font-weight: 500;
      color: #64748b;
      background: #f7f8fa;
      border-bottom: 1px solid #e2e8f0;
      white-space: nowrap;
      user-select: none;
    }

    .trig-table tbody td {
      padding: 10px 16px;
      color: #1a202c;
      border-bottom: 1px solid #edf2f7;
      vertical-align: middle;
    }

    .trig-table tbody tr:last-child td {
      border-bottom: none;
    }

    .trig-table tbody tr:hover {
      background: #f7f8fa;
    }

    /* Monospace names */
    .trig-table__mono {
      font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', Consolas, monospace;
      font-size: 13px;
      color: #1a202c;
    }

    /* Table name link */
    .trig-table__table-link {
      font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', Consolas, monospace;
      font-size: 13px;
      color: #3b82f6;
      text-decoration: none;
      cursor: pointer;
    }

    .trig-table__table-link:hover {
      text-decoration: underline;
    }

    /* Event / Timing pills */
    .trig-table__pill {
      display: inline-block;
      padding: 2px 8px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.04em;
      line-height: 1.4;
      border-radius: 4px;
      white-space: nowrap;
    }

    .trig-table__pill--event-insert {
      background: #eff6ff;
      color: #2563eb;
    }

    .trig-table__pill--event-update {
      background: #fefce8;
      color: #ca8a04;
    }

    .trig-table__pill--event-delete {
      background: #fef2f2;
      color: #dc2626;
    }

    .trig-table__pill--timing-before {
      background: #f0fdf4;
      color: #16a34a;
    }

    .trig-table__pill--timing-after {
      background: #faf5ff;
      color: #9333ea;
    }

    /* Toggle switch 40x22 */
    .trig-toggle {
      position: relative;
      display: inline-block;
      width: 40px;
      height: 22px;
      cursor: pointer;
    }

    .trig-toggle input {
      opacity: 0;
      width: 0;
      height: 0;
      position: absolute;
    }

    .trig-toggle__track {
      position: absolute;
      inset: 0;
      border-radius: 11px;
      background: #cbd5e1;
      transition: background 150ms ease;
    }

    .trig-toggle input:checked + .trig-toggle__track {
      background: #22c55e;
    }

    .trig-toggle__thumb {
      position: absolute;
      top: 2px;
      left: 2px;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: #ffffff;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
      transition: transform 150ms ease;
      pointer-events: none;
    }

    .trig-toggle input:checked ~ .trig-toggle__thumb {
      transform: translateX(18px);
    }

    /* Count footer */
    .trig-page__count {
      margin-top: 12px;
      font-size: 13px;
      color: #64748b;
    }
  </style>

  <!-- Shell Structure -->
  <div class="project-shell">

    <!-- Header -->
    <header class="shell-header">
      <div class="shell-header__left">
        <span class="shell-header__org">my-org</span>
        <span class="shell-header__badge shell-header__badge--free">FREE</span>
      </div>

      <div class="shell-header__center">
        <span class="shell-header__breadcrumb">my-project<span class="shell-header__breadcrumb-sep"> &gt; </span>main</span>
        <span class="shell-header__badge shell-header__badge--prod">PRODUCTION</span>
      </div>

      <div class="shell-header__right">
        <button class="shell-header__connect">Connect</button>
        <button class="shell-header__icon-btn" aria-label="Search">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        <button class="shell-header__icon-btn" aria-label="Help">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </button>
        <div class="shell-header__avatar" title="User"></div>
      </div>
    </header>

    <!-- Body: Sidebar + Main -->
    <div class="shell-body">

      <!-- Sidebar Navigation -->
      <nav class="shell-sidebar">

        <!-- DATABASE MANAGEMENT -->
        <div class="shell-sidebar__section-title">Database Management</div>
        <a class="shell-sidebar__nav-item" href="#" data-nav-key="schema-visualizer" data-dom-id="nav-schema-viz">Schema Visualizer</a>
        <a class="shell-sidebar__nav-item" href="#" data-nav-key="tables" data-dom-id="nav-tables">Tables</a>
        <a class="shell-sidebar__nav-item" href="#" data-nav-key="functions" data-dom-id="nav-functions">Functions</a>
        <a class="shell-sidebar__nav-item" href="#" data-nav-key="triggers" data-dom-id="nav-triggers" data-active="true">Triggers</a>
        <a class="shell-sidebar__nav-item" href="#" data-nav-key="enumerated-types" data-dom-id="nav-enums">Enumerated Types</a>
        <a class="shell-sidebar__nav-item" href="#" data-nav-key="extensions" data-dom-id="nav-extensions">Extensions</a>
        <a class="shell-sidebar__nav-item" href="#" data-nav-key="indexes" data-dom-id="nav-indexes">Indexes</a>
        <a class="shell-sidebar__nav-item" href="#" data-nav-key="publications" data-dom-id="nav-publications">Publications</a>

        <!-- ACCESS CONTROL -->
        <div class="shell-sidebar__section-title">Access Control</div>
        <a class="shell-sidebar__nav-item" href="#" data-nav-key="policies" data-dom-id="nav-policies">Policies</a>
        <a class="shell-sidebar__nav-item" href="#" data-nav-key="roles" data-dom-id="nav-roles">Roles</a>

        <!-- CONFIGURATION -->
        <div class="shell-sidebar__section-title">Configuration</div>
        <a class="shell-sidebar__nav-item" href="#" data-nav-key="settings" data-dom-id="nav-settings">Settings</a>

      </nav>

      <!-- Main Content Area -->
      <main class="shell-main" id="page-content">
        <div id="page-slot">

          <div class="trig-page">

            <!-- Page header -->
            <div class="trig-page__header">
              <h2 class="trig-page__title">Database Triggers</h2>
              <a class="trig-page__docs-link" href="#">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                Docs
              </a>
            </div>

            <!-- Toolbar -->
            <div class="trig-toolbar">
              <select class="trig-toolbar__schema-select">
                <option>schema public</option>
              </select>
              <input class="trig-toolbar__search" type="text" placeholder="Search for a trigger" />
              <div class="trig-toolbar__spacer"></div>
              <button class="trig-toolbar__btn-new">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                New trigger
              </button>
            </div>

            <!-- Data table -->
            <div class="trig-table-wrap">
              <table class="trig-table">
                <thead>
                  <tr>
                    <th>TRIGGER NAME</th>
                    <th>TABLE</th>
                    <th>EVENT</th>
                    <th>TIMING</th>
                    <th>FUNCTION</th>
                    <th>ENABLED</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><span class="trig-table__mono">update_updated_at</span></td>
                    <td><a class="trig-table__table-link" href="#">posts</a></td>
                    <td><span class="trig-table__pill trig-table__pill--event-update">UPDATE</span></td>
                    <td><span class="trig-table__pill trig-table__pill--timing-before">BEFORE</span></td>
                    <td><span class="trig-table__mono">update_timestamp()</span></td>
                    <td>
                      <label class="trig-toggle">
                        <input type="checkbox" checked />
                        <span class="trig-toggle__track"></span>
                        <span class="trig-toggle__thumb"></span>
                      </label>
                    </td>
                  </tr>
                  <tr>
                    <td><span class="trig-table__mono">notify_new_post</span></td>
                    <td><a class="trig-table__table-link" href="#">posts</a></td>
                    <td><span class="trig-table__pill trig-table__pill--event-insert">INSERT</span></td>
                    <td><span class="trig-table__pill trig-table__pill--timing-after">AFTER</span></td>
                    <td><span class="trig-table__mono">send_notification()</span></td>
                    <td>
                      <label class="trig-toggle">
                        <input type="checkbox" checked />
                        <span class="trig-toggle__track"></span>
                        <span class="trig-toggle__thumb"></span>
                      </label>
                    </td>
                  </tr>
                  <tr>
                    <td><span class="trig-table__mono">validate_email</span></td>
                    <td><a class="trig-table__table-link" href="#">users</a></td>
                    <td><span class="trig-table__pill trig-table__pill--event-insert">INSERT</span></td>
                    <td><span class="trig-table__pill trig-table__pill--timing-before">BEFORE</span></td>
                    <td><span class="trig-table__mono">validate_email_fn()</span></td>
                    <td>
                      <label class="trig-toggle">
                        <input type="checkbox" />
                        <span class="trig-toggle__track"></span>
                        <span class="trig-toggle__thumb"></span>
                      </label>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>

            <!-- Count -->
            <div class="trig-page__count">3 triggers</div>

          </div>

        </div>
      </main>

    </div>
  </div>
</body>
</html>

