# ============================================
# 生产环境配置
# 继承 .env 后覆盖以下值
# ============================================

# 环境标识
DENO_ENV=production

# Docker 镜像标签
IMAGE_TAG=prod

# PostgREST（生产环境地址，敏感信息通过环境变量注入）
PGREST_URL=${PGREST_URL}

# External auth service（生产环境地址，敏感信息通过环境变量注入）
IA_CSC_BASE_URL=${IA_CSC_BASE_URL}

# 生产环境日志级别
LOG_LEVEL=error

# 生产环境 CORS 应该限制具体域名
CORS_ORIGIN=${CORS_ORIGIN}
