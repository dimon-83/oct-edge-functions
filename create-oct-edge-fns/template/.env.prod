# ============================================
# 生产环境配置
# 继承 .env 后覆盖以下值
# ============================================

# 环境标识
DENO_ENV=production

# Docker 镜像标签
IMAGE_TAG=prod

# 宿主机端口（生产环境使用 {{PORT_PROD}}，避免与开发环境冲突）
HOST_PORT={{PORT_PROD}}

# PostgREST（生产环境地址，启动时通过环境变量注入）
# 示例: PGREST_URL=http://prod-db:3000 ./start.sh prod
PGREST_URL=

# External auth service（生产环境地址，启动时通过环境变量注入）
IA_CSC_BASE_URL=

# 生产环境日志级别
LOG_LEVEL=error

# 生产环境 CORS 应该限制具体域名（启动时注入）
CORS_ORIGIN=
