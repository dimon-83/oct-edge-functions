# ============================================
# 生产环境配置
# 复制为 .env.prod 后使用
# ============================================

# 环境标识
DENO_ENV=production

# Docker 镜像标签
IMAGE_TAG=prod

# 宿主机端口（生产环境使用 18081，避免与开发环境冲突）
HOST_PORT=18081

# PostgREST（生产环境地址，启动时通过环境变量注入）
# 示例: PGREST_URL=http://prod-db:3000 ./start.sh prod
PGREST_URL=

# 生产环境日志级别
LOG_LEVEL=error

# 生产环境 CORS 应该限制具体域名（启动时注入）
CORS_ORIGIN=
