# Server
PORT=8080
DENO_ENV=development

# PostgREST
PGREST_URL=http://localhost:3000
PGREST_SCHEMA=public

# Auth: PGREST_JWT is read by the default auth middleware (plugins/auth/index.ts)
# WARNING: Development use only. Do NOT use this in production.
# Obtain a temporary or long-lived PostgREST JWT from your admin.
# PGREST_JWT=your_pgrest_jwt_here

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
