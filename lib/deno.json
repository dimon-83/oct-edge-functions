{
  "name": "@oct-edge-fns/core",
  "version": "0.2.1",
  "description": "Edge function runtime core — server, middleware, MCP, plugins, templates for Deno edge functions",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./server": "./server.ts",
    "./middleware": "./middleware.ts",
    "./context": "./context.ts",
    "./logger": "./logger.ts",
    "./db": "./db.ts",
    "./testing": "./testing.ts",
    "./pg": "./pg.ts",
    "./auth": "./plugins/auth.ts",
    "./cron": "./cron/mod.ts"
  },
  "publish": {
    "include": [
      "*.ts",
      "plugins/",
      "templates/",
      "mcp/",
      "cron/",
      "deno.json",
      "README.md"
    ],
    "exclude": [
      "*_test.ts",
      "plugins/*_test.ts",
      "cron/*_test.ts",
      "cron/*_test.node.ts"
    ]
  },
  "tasks": {
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "imports": {
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@supabase/postgrest-js": "npm:@supabase/postgrest-js@^1.18.0",
    "@oct-edge-fns-core/": "./",
    "pg": "npm:pg@^8",
    "pg/": "npm:pg@^8/",
    "@hexagon/croner": "jsr:@hexagon/croner@^8"
  },
  "lint": {
    "include": ["."],
    "exclude": ["templates/"]
  }
}
